{
  "manifest_version": 3,
  "name": "WhatsApp Chat Backup",
  "version": "1.0.0",
  "description": "Download your WhatsApp Web chat history as JSON, TXT, or HTML files.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WhatsApp Chat Backup"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
